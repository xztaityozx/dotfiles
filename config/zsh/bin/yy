#!/usr/bin/env zsh

CMD=""
type clip.exe &> /dev/null && CMD=clip.exe
type pbcopy &> /dev/null && CMD=pbcopy

if [[ -n "$CMD" ]]; then
  "$CMD"
else
  # OSC 52 でクリップボードにコピー (SSH先やpopup内用)
  local data
  data="$(cat | base64)"
  if [[ -n "$TMUX" ]]; then
    printf "\ePtmux;\e\e]52;c;%s\a\e\\" "$data"
  else
    printf "\e]52;c;%s\a" "$data"
  fi
fi
