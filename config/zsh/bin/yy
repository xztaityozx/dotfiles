#!/usr/bin/env zsh

CMD=""
type clip.exe &> /dev/null && CMD=clip.exe
type pbcopy &> /dev/null && CMD=pbcopy

if [[ "$CMD" == "clip.exe" ]]; then
  iconv -f UTF-8 -t UTF-16LE | "$CMD"
elif [[ -n "$CMD" ]]; then
  "$CMD"
elif [[ -n "$TMUX" ]]; then
  # tmux serverにバッファを渡し、-w でOSC 52を実端末に送る
  # popup内のネストされたtmuxでも、サーバー経由で実クライアントに届く
  tmux load-buffer -w -
else
  # tmux外でのOSC 52フォールバック
  local data
  data="$(cat | base64)"
  printf "\e]52;c;%s\a" "$data"
fi
